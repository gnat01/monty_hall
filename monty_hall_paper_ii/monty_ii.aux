\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Compared with purely linear costs, saturating cost curves can make late-stage full revelation optimal again.}}{5}{figure.4}\protected@file@percent }
\newlabel{fig:saturation-push}{{4}{5}{Compared with purely linear costs, saturating cost curves can make late-stage full revelation optimal again}{figure.4}{}}
