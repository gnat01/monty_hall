\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces For $K=50,m=1$, the eliminative-information benefit $\Delta _t$ rises sharply near the end. Different learning-cost curves interact with this same benefit curve in different ways.}}{2}{figure.1}\protected@file@percent }
\newlabel{fig:cost-shapes}{{1}{2}{For $K=50,m=1$, the eliminative-information benefit $\Delta _t$ rises sharply near the end. Different learning-cost curves interact with this same benefit curve in different ways}{figure.1}{}}
\@writefile{toc}{\contentsline {section}{\numberline {3}What Constant Costs Hid}{3}{section.3}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces With linearly increasing reveal costs $c_t=a+bt$, the optimum can occur at no reveal, at full reveal, or at an interior stopping time.}}{3}{figure.2}\protected@file@percent }
\newlabel{fig:linear-regimes}{{2}{3}{With linearly increasing reveal costs $c_t=a+bt$, the optimum can occur at no reveal, at full reveal, or at an interior stopping time}{figure.2}{}}
\@writefile{toc}{\contentsline {section}{\numberline {4}Linearly Increasing Costs}{3}{section.4}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces A phase diagram for $K=50,m=1$ and $c_t=a+bt$. Color indicates the optimal fraction of possible reveals purchased.}}{4}{figure.3}\protected@file@percent }
\newlabel{fig:linear-phase}{{3}{4}{A phase diagram for $K=50,m=1$ and $c_t=a+bt$. Color indicates the optimal fraction of possible reveals purchased}{figure.3}{}}
